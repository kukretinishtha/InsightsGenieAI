# Application
APP_NAME=InsightGenie AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/insightgenie
MONGODB_URL=mongodb+srv://user:password@cluster/insightgenie
DATABASE_ECHO=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_TIMEOUT=5

# Genie API
GENIE_API_KEY=your-genie-api-key
GENIE_API_BASE_URL=https://api.genie.com
GENIE_API_TIMEOUT=30

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/app.log

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Async
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT=300

# Monitoring
SENTRY_DSN=
ENABLE_METRICS=true
