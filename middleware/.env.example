"""
Create .env.example file for middleware.
"""

# Middleware Configuration
ENVIRONMENT=development
DEBUG=true
MIDDLEWARE_HOST=0.0.0.0
MIDDLEWARE_PORT=8001
MIDDLEWARE_WORKERS=4

# Backend Configuration
BACKEND_URL=http://localhost:8000
BACKEND_TIMEOUT=30

# Frontend Configuration
FRONTEND_URL=http://localhost:8501

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=300
REDIS_URL=redis://localhost:6379/0

# Database Configuration
DATABASE_URL=postgresql://insightgenie:changeme@localhost:5432/insightgenie
MONGODB_URL=mongodb://insightgenie:changeme@localhost:27017/insightgenie

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Keys
DEFAULT_API_KEY=sk-default-key
