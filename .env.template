# InsightGenie AI - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# ============================================================================
# Environment Setup
# ============================================================================
ENV=development
DEBUG=true
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json

# ============================================================================
# API Configuration
# ============================================================================
API_TITLE=InsightGenie AI
API_VERSION=1.0.0
API_DESCRIPTION=Real-time Indian Stock Market Prediction with AI Agents

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=4

# CORS Configuration (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/insight_genie

# MongoDB
MONGODB_URL=mongodb://localhost:27017/insight_genie
MONGODB_DB_NAME=insight_genie

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_DB=0
CACHE_TTL=3600

# ============================================================================
# Databricks Configuration (IMPORTANT)
# ============================================================================
# Set ENABLE_DATABRICKS=true to activate Databricks integration

ENABLE_DATABRICKS=false

# Replace with your Databricks workspace URL
# Format: https://<region>.cloud.databricks.com
DATABRICKS_HOST=https://adb-1234567890.cloud.databricks.com

# Replace with your Databricks Personal Access Token
# Generate from: Settings → User Settings → Access Tokens
DATABRICKS_TOKEN=dapi1234567890abcdefghijklmnopqrst

# Databricks Unity Catalog and Schema
DATABRICKS_CATALOG=insightgenie
DATABRICKS_SCHEMA=default

# Databricks Warehouse Configuration (optional)
DATABRICKS_WAREHOUSE_ID=your_warehouse_id
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id

# ============================================================================
# Genie Configuration
# ============================================================================
# Genie Space name for automated dashboards
GENIE_SPACE_NAME=insightgenie-analytics

# Enable/disable automatic insights generation
GENIE_AUTO_INSIGHTS=true

# Enable/disable automatic dashboard creation
GENIE_ENABLE_DASHBOARDS=true

# Dashboard refresh interval (seconds)
GENIE_DASHBOARD_REFRESH_INTERVAL=300

# Genie API Configuration
GENIE_API_URL=https://genie-api.databricks.com/v1
GENIE_MODEL=claude-3-5-sonnet
GENIE_MAX_RETRIES=3
GENIE_TIMEOUT=300
GENIE_POLLING_INTERVAL=100
GENIE_POLLING_MAX_DELAY=5000

# Note: GENIE_API_KEY is typically managed through Databricks token
GENIE_API_KEY=

# ============================================================================
# Stock Market Data Sources
# ============================================================================
# NSE (National Stock Exchange) India
NSE_API_URL=https://www.nseindia.com/api

# BSE (Bombay Stock Exchange) India
BSE_API_URL=https://api.bseindia.com/api

# Optional: External stock data sources
ALPHA_VANTAGE_API_KEY=
FINNHUB_API_KEY=

# ============================================================================
# News and Sentiment Analysis
# ============================================================================
# News API
NEWS_API_URL=https://newsapi.org/v2
NEWS_API_KEY=

# Financial news sources (comma-separated)
FINANCIAL_NEWS_SOURCES=bloomberg,cnbc,reuters,economictimes

# ============================================================================
# Geopolitical Data
# ============================================================================
GEO_API_URL=https://geopolitical-api.example.com
GEO_API_KEY=

# ============================================================================
# Celery Configuration (for async tasks)
# ============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================================
# Authentication & Security
# ============================================================================
# Change this in production!
SECRET_KEY=your-super-secret-key-change-in-production

JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# Performance Configuration
# ============================================================================
MAX_CONCURRENT_AGENTS=3
MAX_CONCURRENT_TOOLS=10
REQUEST_TIMEOUT=300
EXECUTION_TIMEOUT=300

# ============================================================================
# Feature Flags
# ============================================================================
ENABLE_GEOPOLITICAL_ANALYSIS=true
ENABLE_NEWS_ANALYSIS=true
ENABLE_TECHNICAL_ANALYSIS=true
ENABLE_FUNDAMENTAL_ANALYSIS=true
ENABLE_CACHING=true
ENABLE_ASYNC_PROCESSING=true

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_FILE=logs/app.log
LOG_FORMAT=json

# ============================================================================
# Setup Instructions
# ============================================================================
# 1. Copy this file to .env: cp .env.template .env
# 2. Fill in all required values (marked above)
# 3. For development, you can use defaults for local services
# 4. For production, use secure values and external services
# 5. Never commit .env file to version control
#
# Required for full functionality:
# - DATABRICKS_HOST (for data layer storage)
# - DATABRICKS_TOKEN (for authentication)
# - NEWS_API_KEY (for news analysis)
#
# Optional but recommended:
# - ALPHA_VANTAGE_API_KEY (for enhanced stock data)
# - FINNHUB_API_KEY (for additional market data)
# - GEO_API_KEY (for geopolitical analysis)

# ============================================================================
# Development Quick Start
# ============================================================================
# For local development without external services:
# 1. Start PostgreSQL: docker run -d -e POSTGRES_PASSWORD=password -p 5432:5432 postgres
# 2. Start MongoDB: docker run -d -p 27017:27017 mongo
# 3. Start Redis: docker run -d -p 6379:6379 redis
# 4. Set ENABLE_DATABRICKS=false initially
# 5. Run: python -m uvicorn src.main:app --reload

# ============================================================================
# Production Checklist
# ============================================================================
# - Set ENV=production
# - Set DEBUG=false
# - Change SECRET_KEY to a strong random value
# - Use external PostgreSQL (managed service)
# - Use external MongoDB (managed service)
# - Use external Redis (managed service)
# - Set up Databricks workspace and UC
# - Enable all relevant API keys
# - Configure proper CORS origins
# - Set up SSL/TLS certificates
# - Configure logging to centralized system
# - Enable authentication/authorization
# - Set up monitoring and alerting
# - Configure backup and disaster recovery
